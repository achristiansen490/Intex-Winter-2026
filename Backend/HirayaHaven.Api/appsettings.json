{
  "Database": {
    "Provider": "sqlite"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=../../Data/hiraya.db",
    "AzureSqlConnection": "Server=tcp:<your-server>.database.windows.net,1433;Initial Catalog=hiraya-haven;Persist Security Info=False;User ID=<user>;Password=<password>;MultipleActiveResultSets=False;Encrypt=True;TrustServerCertificate=False;Connection Timeout=30;"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5176",
      "http://127.0.0.1:5176"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "HirayaHaven.Api",
    "Audience": "HirayaHaven.Frontend",
    "ExpiryHours": "8"
  }
}
